<section>
  <div class="col-sm-12 col-md-6 demi-box" id="contact-info">

  </div>
  <div class="col-sm-12 col-md-6 demi-box" id="contact-message">
    <form class="form-horizontal" action="index.html" method="post">
      <div class="form-group">
        <input type="text" class="form-control" placeholder="Name" name="name" value="">
      </div>
      <div class="form-group">
        <input type="email" class="form-control" placeholder="Email" name="name" value="">
      </div>
      <div class="form-group">
        <textarea class="form-control" placeholder="Message" name="message" rows="8" cols="40"></textarea>
      </div>
      <div class="form-group">
        <button type="submit" class="btn btn-default" name="button">Send Message</button>
      </div>
    </form>
  </div>
</section>
