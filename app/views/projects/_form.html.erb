<%= simple_form_for(@project) do |f| %>
  <%= f.error_notification %>

  <div class="form-inputs">
    <%= f.input :name %>
    <%= f.input :description, as: :text %>
    <%= f.input :start_date, as: :date, class: 'datepicker' %>
    <%= f.input :end_date, as: :date, class: 'datepicker' %>
  </div>

  <div class="form-actions">
    <%= f.button :submit %>
  </div>
<% end %>
