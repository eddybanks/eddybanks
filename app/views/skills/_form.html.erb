<%= simple_form_for @skill, defaults: { inner_html: { class: 'skills-form' } } do |f| %>
  <%= f.error_notification %>

  <div class="form-inputs">
    <%= f.input :name %>
    <%= f.input :description %>
  </div>

  <div class="form-actions">
    <%#= f.button :submit, input_html: { v-on:submit.prevent: "handleIt" } %>
    <button class="submit" v-on:submit.prevent: "handleIt">Submit!</button>
  </div>
<% end %>
