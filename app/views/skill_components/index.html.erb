<p id="notice"><%= notice %></p>

<h1>Skill Components</h1>

<table>
  <thead>
    <tr>
      <th>Name</th>
      <th>Description</th>
      <th colspan="3"></th>
    </tr>
  </thead>

  <tbody>
    <% @skill_components.each do |skill_component| %>
      <tr>
        <td><%= skill_component.name %></td>
        <td><%= skill_component.description %></td>
        <td><%= link_to 'Show', skill_component %></td>
        <td><%= link_to 'Edit', edit_skill_component_path(skill_component) %></td>
        <td><%= link_to 'Destroy', skill_component, method: :delete, data: { confirm: 'Are you sure?' } %></td>
      </tr>
    <% end %>
  </tbody>
</table>

<br>

<%= link_to 'New Skill Component', new_skill_component_path %>
